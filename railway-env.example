# Klistra in dessa som Variables i Railway (Dashboard → Service → Variables).
# Kopiera värden från er lokala .env – committa ALDRIG .env till GitHub.
# Denna fil är bara en checklista (inga riktiga lösenord).

APP_NAME=Heritage Connect
GEOFENCING_DEMO_MODE=true
AUTO_CREATE_DB_TABLES=true
DATABASE_URL=sqlite:///./heritage_connect.db

# SMS – HelloSMS (riktiga SMS)
SMS_PROVIDER=hellosms
HELLOSMS_API_USERNAME=ert_api_användarnamn
HELLOSMS_API_PASSWORD=ert_api_lösenord
HELLOSMS_SENDER=46764911139
HELLOSMS_TEST_MODE=false

# E-post – Gmail SMTP (riktig e-post)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=er@gmail.com
SMTP_PASSWORD=ert-gmail-app-lösenord
SMTP_FROM=er@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Betalning – Stripe test (4242 4242 4242 4242). Byt till sk_live_… för skarpt.
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# PAYMENT_DEMO_USE_MOCK=true  # endast om ni vill hoppa över Stripe och bara mocka 4242-fält

# BankID – sätt bankid för riktig test (cert auto i testmiljö), se docs/BANKID.md
BANKID_PROVIDER=mock
BANKID_TEST_SERVER=true

# Länkar i SMS (sätt till er Railway-URL – annars fylls RAILWAY_PUBLIC_DOMAIN i automatiskt)
SITE_BASE_URL=https://web-production-e43d0.up.railway.app

# Byt meddelandetjänst till annan grupp (valfritt – tom = er egen HelloSMS)
# NOTIFICATION_SERVICE_URL=https://annan-grupp.example.com

# Övrigt (valfritt)
DEFAULT_HOME_RADIUS_KM=0.1
SITE_NOTIFY_RADIUS_KM=30
NOTIFICATION_COOLDOWN_SECONDS=60
TRANSLATE_PROVIDER=auto
