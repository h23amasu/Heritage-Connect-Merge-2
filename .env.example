# Databas (docker compose up -d)
APP_NAME=Heritage Connect
DATABASE_URL=postgresql://heritage_connect:heritage_connect_dev@localhost:5432/heritage_connect

# Demo utan PostgreSQL
GEOFENCING_DEMO_MODE=true
DEFAULT_HOME_RADIUS_KM=0.1
SITE_NOTIFY_RADIUS_KM=30
NOTIFICATION_COOLDOWN_SECONDS=60

# SMS – HelloSMS (lägg RIKTIGA värden i .env, committa aldrig .env)
SMS_PROVIDER=mock
HELLOSMS_API_USERNAME=
HELLOSMS_API_PASSWORD=
HELLOSMS_SENDER=Heritage C
HELLOSMS_TEST_MODE=true
# Manuellt test-SMS (scripts/test-sms.ps1, diagnose-hellosms.py)
# TEST_SMS_RECIPIENT=+46738100354

# E-post (notification channel=email)
# mock = API success men inget riktigt mail (bara logg i terminal)
# smtp = Gmail m.fl. – se docs/EMAIL.md
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=din@gmail.com
SMTP_PASSWORD=ditt-gmail-app-losenord
SMTP_FROM=din@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=
# SENDGRID_FROM=

# Länkar i SMS (lokal utveckling: http://localhost:8000)
SITE_BASE_URL=http://localhost:8000

# Skapa DB-tabeller vid start (false i produktion med Alembic)
AUTO_CREATE_DB_TABLES=true

# Översättning: auto | dictionary | deep
TRANSLATE_PROVIDER=auto

# Betalning – Stripe test (sk_test_ / pk_test_ från dashboard.stripe.com)
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
AI_PROVIDER=mock

# API-nyckel för testmiljö (valfritt)
API_BEARER_TOKEN=

# Microservices – tom = monolit (samma process som port 8000).
# Sätt URL:erna nedan när du kör docker compose up (matchar docker-compose.yml):
# NOTIFICATION_SERVICE_URL=http://172.28.0.10:8001
# TRANSLATE_SERVICE_URL=http://172.28.0.11:8002
# GEO_SERVICE_URL=http://172.28.0.12:8003
# AI_SERVICE_URL=http://172.28.0.13:8004
# CORE_SERVICE_URL=http://172.28.0.20:8000
NOTIFICATION_SERVICE_URL=
TRANSLATE_SERVICE_URL=
GEO_SERVICE_URL=
AI_SERVICE_URL=
CORE_SERVICE_URL=
